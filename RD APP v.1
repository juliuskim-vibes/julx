function connectDrive() {
  if (!window.google || !window.google.accounts) { alert('Google Sign-In still loading. Please wait and try again.'); return; }
  if (!tokenClient) {
    tokenClient = google.accounts.oauth2.initTokenClient({
      client_id: GDRIVE_CLIENT_ID,
      scope: 'https://www.googleapis.com/auth/drive.file',
      callback: function(response) {
        if (response.error) { alert('Drive connection failed: ' + response.error); return; }
        driveAccessToken = response.access_token;
        var btn = document.getElementById('drive-btn');
        if (btn) { btn.style.background = '#DCFCE7'; btn.style.color = '#166534'; btn.style.borderColor = '#86EFAC'; }
        var txt = document.getElementById('drive-btn-text');
        if (txt) txt.textContent = 'Drive Connected!';
        var st = document.getElementById('drive-status');
        if (st) st.style.display = 'block';
      }
    });
  }
  tokenClient.requestAccessToken();
}

function getOrCreateFolder(folderName, parentId) {
  var q = 'name="' + folderName + '" and mimeType="application/vnd.google-apps.folder" and trashed=false';
  if (parentId) q += ' and "' + parentId + '" in parents';
  return fetch('https://www.googleapis.com/drive/v3/files?q=' + encodeURIComponent(q) + '&fields=files(id,name)', {
    headers: { 'Authorization': 'Bearer ' + driveAccessToken }
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.files && data.files.length > 0) return data.files[0].id;
    var body = { name: folderName, mimeType: 'application/vnd.google-apps.folder' };
    if (parentId) body.parents = [parentId];
    return fetch('https://www.googleapis.com/drive/v3/files', {
      method: 'POST',
      headers: { 'Authorization': 'Bearer ' + driveAccessToken, 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    }).then(function(r) { return r.json(); }).then(function(f) { return f.id; });
  });
}

function uploadToDrive(file, category) {
  if (!driveAccessToken) return Promise.reject(new Error('Google Drive not connected. Click Connect Google Drive first.'));
  return getOrCreateFolder('NEMSU R&D Documents', null).then(function(rootId) {
    driveRootId = rootId;
    return getOrCreateFolder(category, rootId);
  }).then(function(catId) {
    if (category === 'PPMP & Procurement' && detectedData && detectedData.title) {
      return getOrCreateFolder(detectedData.title, catId);
    }
    return catId;
  }).then(function(folderId) {
    var metadata = { name: file.name, parents: [folderId] };
    var form = new FormData();
    form.append('metadata', new Blob([JSON.stringify(metadata)], { type: 'application/json' }));
    form.append('file', file);
    return fetch('https://www.googleapis.com/upload/drive/v3/files?uploadType=multipart&fields=id,name,webViewLink', {
      method: 'POST', headers: { 'Authorization': 'Bearer ' + driveAccessToken }, body: form
    });
  }).then(function(res) {
    if (!res.ok) return res.json().then(function(e) { throw new Error(e.error ? e.error.message : 'Upload failed'); });
    return res.json();
  });
}

function saveToNote() {
  if (!currentFile || !detectedData) return;
  var cat = detectedData.category || 'Forms & Templates';
  showStatus('status-dash', 'loading', '<span class="spinner"></span> Uploading to Google Drive...');
  showStatus('status-up', 'loading', '<span class="spinner"></span> Uploading to Google Drive...');
  document.getElementById('btn-save-dash').disabled = true;
  document.getElementById('btn-save-up').disabled = true;
  uploadToDrive(currentFile, cat).then(function(result) {
    folderCounts[cat] = (folderCounts[cat] || 0) + 1;
    uploadCount++;
    var idx = uploadCount % FILE_COLORS.length;
    var ext = currentFile.name.split('.').pop().toUpperCase().slice(0,4);
    var link = result.webViewLink || '';
    recentUploads.unshift({ name: currentFile.name, cat: cat, ext: ext, color: FILE_COLORS[idx], bg: FILE_BG[idx], time: 'Just now', link: link });
    if (recentUploads.length > 6) recentUploads.pop();
    updateRecentList();
    buildFolderGrid();
    updateStats();
    var msg = link ? 'Saved! <a href="' + link + '" target="_blank" style="color:#166534;font-weight:600;">View in Google Drive</a>' : 'Saved to Google Drive — ' + cat + '/';
    showStatus('status-dash', 'success', msg);
    showStatus('status-up', 'success', msg);
    currentFile = null;
    detectedData = {};
    setTimeout(function() {
      document.getElementById('ai-preview-dash').style.display = 'none';
      document.getElementById('ai-preview-up').style.display = 'none';
      hideStatus('status-dash');
      hideStatus('status-up');
      document.getElementById('btn-save-dash').disabled = false;
      document.getElementById('btn-save-up').disabled = false;
      document.getElementById('file-input-dash').value = '';
      document.getElementById('file-input-up').value = '';
    }, 5000);
  }).catch(function(err) {
    showStatus('status-dash', 'error', 'Upload failed: ' + err.message);
    showStatus('status-up', 'error', 'Upload failed: ' + err.message);
    document.getElementById('btn-save-dash').disabled = false;
    document.getElementById('btn-save-up').disabled = false;
  });
}

function updateRecentList() {
  var list = document.getElementById('recent-list');
  if (!list) return;
  if (recentUploads.length === 0) {
    list.innerHTML = '<div style="text-align:center;padding:30px 0;color:var(--text3);font-size:12px;">No documents uploaded yet.</div>';
    return;
  }
  list.innerHTML = recentUploads.map(function(u) {
    return '<div class="recent-item"><div class="file-badge" style="background:' + u.bg + ';color:' + u.color + ';">' + u.ext + '</div>' +
      '<div class="recent-info"><div class="recent-name">' + u.name + '</div><div class="recent-meta">' + u.cat + ' · ' + u.time + '</div></div>' +
      '<span class="badge badge-green">Saved</span></div>';
  }).join('');
}

function getRootFolderId() {
  if (driveRootId) return Promise.resolve(driveRootId);
  return fetch('https://www.googleapis.com/drive/v3/files?q=' + encodeURIComponent('name="NEMSU R&D Documents" and mimeType="application/vnd.google-apps.folder" and trashed=false') + '&fields=files(id,name)', {
    headers: { 'Authorization': 'Bearer ' + driveAccessToken }
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.files && data.files.length > 0) { driveRootId = data.files[0].id; return driveRootId; }
    return null;
  });
}

function findFolderInParent(name, parentId) {
  if (!parentId) return Promise.resolve(null);
  return fetch('https://www.googleapis.com/drive/v3/files?q=' + encodeURIComponent('name="' + name + '" and mimeType="application/vnd.google-apps.folder" and "' + parentId + '" in parents and trashed=false') + '&fields=files(id,name)', {
    headers: { 'Authorization': 'Bearer ' + driveAccessToken }
  }).then(function(r) { return r.json(); }).then(function(data) {
    return (data.files && data.files.length > 0) ? data.files[0].id : null;
  });
}

function loadFolderFiles(folderName) {
  var listEl = document.getElementById('folder-file-list');
  if (!driveAccessToken) {
    listEl.innerHTML = '<div style="text-align:center;padding:40px 0;"><div style="font-size:13px;color:var(--text3);margin-bottom:12px;">Connect Google Drive to view files.</div><button class="btn-upload" onclick="connectDrive()" style="font-size:12px;padding:8px 16px;">Connect Google Drive</button></div>';
    document.getElementById('folder-view-count').textContent = '—';
    return;
  }
  listEl.innerHTML = '<div style="text-align:center;padding:40px 0;color:var(--text3);font-size:13px;"><span class="spinner" style="border-color:var(--blue);border-top-color:transparent;"></span> Loading from Google Drive...</div>';
  getRootFolderId().then(function(rootId) {
    return findFolderInParent(folderName, rootId);
  }).then(function(folderId) {
    if (!folderId) {
      listEl.innerHTML = '<div style="text-align:center;padding:40px 0;color:var(--text3);font-size:13px;">No files uploaded yet in this folder.</div>';
      document.getElementById('folder-view-count').textContent = '0 files';
      return;
    }
    return fetch('https://www.googleapis.com/drive/v3/files?q=' + encodeURIComponent('"' + folderId + '" in parents and trashed=false') + '&fields=files(id,name,mimeType,createdTime,size,webViewLink)&orderBy=createdTime desc', {
      headers: { 'Authorization': 'Bearer ' + driveAccessToken }
    }).then(function(r) { return r.json(); }).then(function(data) {
      var files = data.files || [];
      currentFolderFiles = files;
      document.getElementById('folder-view-count').textContent = files.length + ' file' + (files.length !== 1 ? 's' : '');
      folderCounts[folderName] = files.length;
      updateStats();
      buildFolderGrid();
      if (files.length === 0) {
        listEl.innerHTML = '<div style="text-align:center;padding:40px 0;color:var(--text3);font-size:13px;">No files uploaded yet in this folder.</div>';
        return;
      }
      listEl.innerHTML = files.map(function(f) {
        var ext = f.name.split('.').pop().toUpperCase().slice(0,4);
        var colorIdx = ['PDF','DOC','XLS','JPG','PNG'].indexOf(ext);
        var colors = ['#1B4FD8','#166534','#92400E','#9F1239','#5B21B6'];
        var bgs = ['#EBF0FD','#DCFCE7','#FEF3C7','#FFE4E6','#EDE9FE'];
        var c = colors[colorIdx >= 0 ? colorIdx : 0];
        var bg = bgs[colorIdx >= 0 ? colorIdx : 0];
        var date = f.createdTime ? new Date(f.createdTime).toLocaleDateString('en-PH', {year:'numeric',month:'short',day:'numeric'}) : '';
        var size = f.size ? (f.size > 1048576 ? (f.size/1048576).toFixed(1) + ' MB' : (f.size/1024).toFixed(0) + ' KB') : '';
        return '<div class="recent-item" style="padding:12px 0;">' +
          '<div class="file-badge" style="background:' + bg + ';color:' + c + ';width:36px;height:36px;font-size:9px;">' + ext + '</div>' +
          '<div class="recent-info" style="flex:1;min-width:0;"><div class="recent-name" style="font-size:13px;">' + f.name + '</div>' +
          '<div class="recent-meta" style="font-size:11px;">' + date + (size ? ' · ' + size : '') + '</div></div>' +
          '<div style="display:flex;gap:6px;">' +
          (f.webViewLink ? '<a href="' + f.webViewLink + '" target="_blank" style="display:inline-flex;align-items:center;gap:5px;padding:6px 12px;background:var(--blue-light);color:var(--blue);border:1px solid var(--blue-mid);border-radius:6px;font-size:11px;font-weight:500;text-decoration:none;white-space:nowrap;">Open in Drive</a>' : '') +
          '<button onclick="deleteFile(this)" data-id="' + f.id + '" data-name="' + encodeURIComponent(f.name) + '" style="display:inline-flex;align-items:center;gap:4px;padding:6px 10px;background:var(--red-light);color:var(--red);border:1px solid var(--red);border-radius:6px;font-size:11px;font-weight:500;cursor:pointer;white-space:nowrap;">Delete</button>' +
          '</div>' +
          '</div>';
      }).join('');
    });
  }).catch(function(err) {
    listEl.innerHTML = '<div style="text-align:center;padding:40px 0;color:var(--red);font-size:13px;">Error: ' + err.message + '</div>';
    document.getElementById('folder-view-count').textContent = 'Error';
  });
}

function refreshFolderView() { if (currentFolderName) loadFolderFiles(currentFolderName); }

function exportFolderData() {
  if (currentFolderFiles.length === 0) { alert('No files to export. Load a folder first.'); return; }
  var rows = ['File Name,Date Uploaded,Google Drive Link'];
  currentFolderFiles.forEach(function(f) {
    var date = f.createdTime ? new Date(f.createdTime).toLocaleDateString('en-PH') : '';
    rows.push('"' + f.name.replace(/"/g,'""') + '","' + date + '","' + (f.webViewLink || '') + '"');
  });
  var blob = new Blob([rows.join('\n')], { type: 'text/csv' });
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url;
  a.download = currentFolderName.replace(/[^a-z0-9]/gi,'_') + '_export.csv';
  a.click();
  URL.revokeObjectURL(url);
}

function doSearch() {
  var query = document.getElementById('search-input').value.trim();
  var category = document.getElementById('search-category').value;
  var listEl = document.getElementById('search-results-list');
  var countEl = document.getElementById('search-results-count');
  var titleEl = document.getElementById('search-results-title');
  if (!driveAccessToken) {
    listEl.innerHTML = '<div style="text-align:center;padding:40px 0;"><div style="font-size:13px;color:var(--text3);margin-bottom:12px;">Connect Google Drive to search files.</div><button class="btn-upload" onclick="connectDrive()" style="font-size:12px;padding:8px 16px;">Connect Google Drive</button></div>';
    return;
  }
  if (!query && !category) {
    listEl.innerHTML = '<div style="text-align:center;padding:40px 0;color:var(--text3);font-size:13px;">Please enter a search term or select a category.</div>';
    return;
  }
  listEl.innerHTML = '<div style="text-align:center;padding:40px 0;color:var(--text3);font-size:13px;"><span class="spinner" style="border-color:var(--blue);border-top-color:transparent;"></span> Searching...</div>';
  countEl.textContent = '';
  titleEl.textContent = 'Results for: ' + (query || category);
  getRootFolderId().then(function(rootId) {
    if (!rootId) {
      listEl.innerHTML = '<div style="text-align:center;padding:40px 0;color:var(--text3);font-size:13px;">No documents folder found yet.</div>';
      return;
    }
    return searchInFolder(rootId, query, category).then(function(files) {
      if (files.length === 0) {
        listEl.innerHTML = '<div style="text-align:center;padding:40px 0;color:var(--text3);font-size:13px;">No files found.</div>';
        countEl.textContent = '0 results';
        return;
      }
      countEl.textContent = files.length + ' result' + (files.length !== 1 ? 's' : '') + ' found';
      listEl.innerHTML = files.map(function(f) {
        var ext = f.name.split('.').pop().toUpperCase().slice(0,4);
        var colorIdx = ['PDF','DOC','XLS','JPG','PNG'].indexOf(ext);
        var colors = ['#1B4FD8','#166534','#92400E','#9F1239','#5B21B6'];
        var bgs = ['#EBF0FD','#DCFCE7','#FEF3C7','#FFE4E6','#EDE9FE'];
        var c = colors[colorIdx >= 0 ? colorIdx : 0];
        var bg = bgs[colorIdx >= 0 ? colorIdx : 0];
        var date = f.createdTime ? new Date(f.createdTime).toLocaleDateString('en-PH', {year:'numeric',month:'short',day:'numeric'}) : '';
        var badgeClass = BADGE_COLORS[f.folderName] || 'badge-blue';
        return '<div class="recent-item" style="padding:12px 0;">' +
          '<div class="file-badge" style="background:' + bg + ';color:' + c + ';width:36px;height:36px;font-size:9px;">' + ext + '</div>' +
          '<div class="recent-info" style="flex:1;min-width:0;"><div class="recent-name" style="font-size:13px;">' + f.name + '</div>' +
          '<div class="recent-meta" style="font-size:11px;display:flex;align-items:center;gap:6px;"><span class="badge ' + badgeClass + '" style="font-size:9px;">' + (f.folderName || '') + '</span>' + (date ? ' · ' + date : '') + '</div></div>' +
          (f.webViewLink ? '<a href="' + f.webViewLink + '" target="_blank" style="display:inline-flex;align-items:center;gap:5px;padding:6px 12px;background:var(--blue-light);color:var(--blue);border:1px solid var(--blue-mid);border-radius:6px;font-size:11px;font-weight:500;text-decoration:none;white-space:nowrap;">Open in Drive</a>' : '') +
          '</div>';
      }).join('');
    });
  }).catch(function(err) {
    listEl.innerHTML = '<div style="text-align:center;padding:30px 0;color:var(--red);font-size:13px;">Search error: ' + err.message + '</div>';
  });
}

function searchInFolder(rootId, query, categoryFilter) {
  return fetch('https://www.googleapis.com/drive/v3/files?q=' + encodeURIComponent('"' + rootId + '" in parents and mimeType="application/vnd.google-apps.folder" and trashed=false') + '&fields=files(id,name)', {
    headers: { 'Authorization': 'Bearer ' + driveAccessToken }
  }).then(function(r) { return r.json(); }).then(function(data) {
    var folders = data.files || [];
    if (categoryFilter) folders = folders.filter(function(f) { return f.name === categoryFilter; });
    var promises = folders.map(function(folder) {
      var q = '"' + folder.id + '" in parents and trashed=false and mimeType!="application/vnd.google-apps.folder"';
      if (query) q += ' and name contains "' + query.replace(/"/g,'') + '"';
      return fetch('https://www.googleapis.com/drive/v3/files?q=' + encodeURIComponent(q) + '&fields=files(id,name,mimeType,createdTime,size,webViewLink)&orderBy=createdTime desc', {
        headers: { 'Authorization': 'Bearer ' + driveAccessToken }
      }).then(function(r) { return r.json(); }).then(function(data) {
        return (data.files || []).map(function(f) { f.folderName = folder.name; return f; });
      });
    });
    return Promise.all(promises).then(function(results) {
      var all = [];
      results.forEach(function(r) { all = all.concat(r); });
      all.sort(function(a,b) { return new Date(b.createdTime) - new Date(a.createdTime); });
      return all;
    });
  });
}

function toggleDarkMode() {
  isDarkMode = !isDarkMode;
  document.body.classList.toggle('dark-mode', isDarkMode);
  var knob = document.getElementById('dark-knob');
  var toggle = document.getElementById('dark-toggle');
  if (knob) knob.style.left = isDarkMode ? '22px' : '2px';
  if (toggle) toggle.style.background = isDarkMode ? 'var(--blue)' : 'var(--border2)';
  localStorage.setItem('nemsu_darkmode', isDarkMode ? '1' : '0');
}

function renderUsersList() {
  var ul = document.getElementById('users-list');
  if (!ul) return;
  ul.innerHTML = Object.keys(USERS).map(function(u) {
    return '<div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);">' +
      '<span style="font-size:13px;color:var(--text);">' + u + '</span>' +
      (u !== 'rdoadmin' ? '<button onclick="removeUser(\'' + u + '\')" style="font-size:11px;padding:4px 10px;background:var(--red-light);color:var(--red);border:none;border-radius:4px;cursor:pointer;">Remove</button>' : '<span style="font-size:11px;color:var(--text3);">Admin</span>') +
    '</div>';
  }).join('');
}

function addUser() {
  var u = document.getElementById('new-username').value.trim();
  var p = document.getElementById('new-userpass').value;
  var msg = document.getElementById('user-msg');
  if (!u || !p) { msg.style.display='block'; msg.style.color='var(--red)'; msg.textContent='Please enter username and password.'; return; }
  if (USERS[u]) { msg.style.display='block'; msg.style.color='var(--red)'; msg.textContent='Username already exists.'; return; }
  USERS[u] = p;
  document.getElementById('new-username').value = '';
  document.getElementById('new-userpass').value = '';
  msg.style.display='block'; msg.style.color='var(--green)'; msg.textContent='User added!';
  renderUsersList();
  setTimeout(function() { msg.style.display='none'; }, 3000);
}

function removeUser(u) {
  if (!confirm('Remove user: ' + u + '?')) return;
  delete USERS[u];
  renderUsersList();
}

function changePassword() {
  var oldP = document.getElementById('old-password').value;
  var newP = document.getElementById('new-password').value;
  var confP = document.getElementById('confirm-password').value;
  var msg = document.getElementById('pwd-msg');
  var currentUser = document.getElementById('user-display').textContent;
  if (!USERS[currentUser] || USERS[currentUser] !== oldP) { msg.style.display='block'; msg.style.color='var(--red)'; msg.textContent='Current password is incorrect.'; return; }
  if (newP.length < 6) { msg.style.display='block'; msg.style.color='var(--red)'; msg.textContent='Password must be at least 6 characters.'; return; }
  if (newP !== confP) { msg.style.display='block'; msg.style.color='var(--red)'; msg.textContent='Passwords do not match.'; return; }
  USERS[currentUser] = newP;
  ['old-password','new-password','confirm-password'].forEach(function(id) { document.getElementById(id).value = ''; });
  msg.style.display='block'; msg.style.color='var(--green)'; msg.textContent='Password updated!';
  setTimeout(function() { msg.style.display='none'; }, 3000);
}

function openModal() { document.getElementById('edit-modal').style.display = 'flex'; }
function closeModal() { document.getElementById('edit-modal').style.display = 'none'; }

function applyEdit() {
  if (!detectedData) detectedData = {};
  detectedData.title = document.getElementById('edit-title').value;
  detectedData.author = document.getElementById('edit-author').value;
  detectedData.date = document.getElementById('edit-date').value;
  detectedData.category = document.getElementById('edit-category').value;
  populatePreview(detectedData);
  closeModal();
}

function showStatus(id, type, msg) {
  var el = document.getElementById(id);
  if (!el) return;
  el.className = 'status-msg status-' + type;
  el.innerHTML = msg;
  el.style.display = 'block';
}

function hideStatus(id) {
  var el = document.getElementById(id);
  if (el) el.style.display = 'none';
}

function deleteFile(btn) {
  var fileId = btn.getAttribute('data-id');
  var fileName = decodeURIComponent(btn.getAttribute('data-name'));
  if (!confirm('Are you sure you want to delete "' + fileName + '"?\nThis will permanently delete the file from Google Drive.')) return;
  if (!driveAccessToken) { alert('Google Drive not connected.'); return; }
  fetch('https://www.googleapis.com/drive/v3/files/' + fileId, {
    method: 'DELETE',
    headers: { 'Authorization': 'Bearer ' + driveAccessToken }
  }).then(function(res) {
    if (res.ok || res.status === 204) {
      currentFolderFiles = currentFolderFiles.filter(function(f) { return f.id !== fileId; });
      if (folderCounts[currentFolderName] > 0) folderCounts[currentFolderName]--;
      updateStats();
      buildFolderGrid();
      loadFolderFiles(currentFolderName);
    } else {
      res.json().then(function(e) {
        alert('Delete failed: ' + (e.error ? e.error.message : 'Unknown error'));
      });
    }
  }).catch(function(err) {
    alert('Delete error: ' + err.message);
  });
}

document.addEventListener('DOMContentLoaded', function() {
  ['drop-zone-dash','drop-zone-up'].forEach(function(id) {
    var zone = document.getElementById(id);
    if (!zone) return;
    zone.addEventListener('dragover', function(e) { e.preventDefault(); zone.classList.add('dragover'); });
    zone.addEventListener('dragleave', function() { zone.classList.remove('dragover'); });
    zone.addEventListener('drop', function(e) {
      e.preventDefault();
      zone.classList.remove('dragover');
      var file = e.dataTransfer.files[0];
      if (file) handleFile(file);
    });
  });
  buildFolderGrid();
  var savedDark = localStorage.getItem('nemsu_darkmode');
  if (savedDark === '1') toggleDarkMode();
});

</script>
</body>
</html>
