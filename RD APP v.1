    if (el) el.textContent = d.date || 'N/A';
    el = document.getElementById('p-folder' + sfx);
    if (el) el.textContent = cat + '/';
  });
  var sel = document.getElementById('edit-category');
  if (sel) {
    for (var i = 0; i < sel.options.length; i++) {
