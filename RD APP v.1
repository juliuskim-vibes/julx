function extractDOI(text) {
  var patterns = ['10\\.\\d{4,}\\/\\S+', 'doi\\.org\\/(10\\.\\S+)', 'dx\\.doi\\.org\\/(10\\.\\S+)'];
  for (var i = 0; i < patterns.length; i++) {
    var m = text.match(new RegExp(patterns[i], 'i'));
    if (m) return m[0].replace(/[.,;)]+$/, '');
  }
  return null;
}

function guessFromFilename(filename) {
  var fn = filename.toLowerCase().replace(/[_\-]/g, ' ').replace(/\.\w+$/, '');
  var map = [
    ['R&D Proposals', ['proposal','research proposal','rd proposal','project proposal']],
    ['Activity Proposals', ['activity','seminar','training','workshop','capability']],
    ['Progress Reports', ['progress','status report','quarterly','q1 ','q2 ','q3 ','q4 ']],
    ['Terminal Reports', ['terminal','final report','completion']],
    ['TEG Reports', ['teg','technical eval','panel eval']],
    ['Publications & Presentations', ['publication','paper','journal','article','conference','presentation','manuscript','lucagbo']],
    ['PPMP & Procurement', ['ppmp','purchase','rfq','canvass','procurement']],
    ['MOA / MOU Documents', ['moa','mou','memorandum','agreement']],
    ['Certificates & Awards', ['certificate','award','recognition','plaque']],
    ['Monitoring & Evaluation', ['monitoring','evaluation','logbook']],
    ['Completed Researches', ['completed','finished']],
    ['Letter Requests', ['letter','request','endorsement','intent']],
    ['Forms & Templates', ['form','template','blank']],
    ['Creative Works', ['creative','artwork','literary']],
    ['Extension Documents', ['extension','community','outreach']]
  ];
  for (var i = 0; i < map.length; i++) {
    for (var j = 0; j < map[i][1].length; j++) {
      if (fn.indexOf(map[i][1][j]) >= 0) return map[i][0];
    }
  }
  return null;
}

function readFileText(file) {
  return new Promise(function(resolve) {
    var name = file.name;
    var ext = name.split('.').pop().toLowerCase();
    if (file.type.startsWith('image/') || ['jpg','jpeg','png','gif','bmp','webp'].indexOf(ext) >= 0) {
      resolve('FILENAME: ' + name + '\nThis is an image file.');
      return;
    }
    var reader = new FileReader();
    if (ext === 'pdf') {
      reader.onload = function(e) {
        try {
          var arr = new Uint8Array(e.target.result);
          var raw = '';
          for (var i = 0; i < Math.min(arr.length, 80000); i++) {
            var c = arr[i];
            if (c >= 32 && c < 127) raw += String.fromCharCode(c);
            else if (c === 10 || c === 13) raw += ' ';
          }
          var words = [];
          var word = '';
          for (var i = 0; i < raw.length; i++) {
            var ch = raw[i];
            if (ch === ' ' || ch === '\t') {
              if (word.length >= 3) words.push(word);
              word = '';
            } else {
              word += ch;
            }
          }
          var text = words.join(' ').slice(0, 4000);
          resolve('FILENAME: ' + name + '\nEXTRACTED TEXT:\n' + text);
        } catch(err) {
          resolve('FILENAME: ' + name);
        }
      };
      reader.onerror = function() { resolve('FILENAME: ' + name); };
      reader.readAsArrayBuffer(file);
    } else {
      reader.onload = function(e) {
        resolve('FILENAME: ' + name + '\nCONTENT:\n' + (e.target.result || '').slice(0, 4000));
      };
      reader.onerror = function() { resolve('FILENAME: ' + name); };
      reader.readAsText(file);
    }
  });
}

function getModel() {
  if (window._geminiModel) return Promise.resolve(window._geminiModel);
  return fetch('https://generativelanguage.googleapis.com/v1beta/models?key=' + apiKey)
    .then(function(r) { if (!r.ok) throw new Error('Cannot list models'); return r.json(); })
    .then(function(data) {
      var models = (data.models || []).filter(function(m) {
        return m.supportedGenerationMethods && m.supportedGenerationMethods.indexOf('generateContent') >= 0;
      });
      var priority = ['gemini-2.5-flash','gemini-2.0-flash','gemini-1.5-flash','gemini-pro'];
      for (var i = 0; i < priority.length; i++) {
        var found = models.find(function(m) { return m.name.toLowerCase().indexOf(priority[i]) >= 0; });
        if (found) { window._geminiModel = found.name.replace('models/',''); return window._geminiModel; }
      }
      if (models.length > 0) { window._geminiModel = models[0].name.replace('models/',''); return window._geminiModel; }
      throw new Error('No usable Gemini model found');
    });
}

function callGemini(textContent, filename) {
  return getModel().then(function(model) {
    var catList = CATEGORIES.join(', ');
    var filenameGuess = guessFromFilename(filename);
    var doi = extractDOI(textContent);
    var contentHint = filenameGuess ? 'Filename suggests: ' + filenameGuess + '. ' : '';
    var doiHint = doi ? 'DOI found: ' + doi + ' - this is a publication. ' : '';
    var prompt = 'You are a document classifier for NEMSU R&D Office Philippines. '
      + 'FILENAME: ' + filename + '. '
      + contentHint + doiHint
      + 'DOCUMENT HEADER: ' + textContent.slice(0, 500) + '. '
      + 'FULL CONTENT: ' + textContent.slice(0, 3000) + '. '
      + 'CATEGORIES: ' + catList + '. '
      + 'RULES: 1)Use filename hint if clear. 2)Find title in first 200 chars. '
      + '3)Find author after Prepared by/Proponent/By/Researcher. '
      + '4)Find date as Month Year or YYYY-MM-DD. '
      + '5)If DOI exists set category to Publications and Presentations. '
      + 'Reply ONLY with valid JSON no markdown: '
      + '{"category":"exact category","title":"title from content","author":"name or N/A","date":"date or N/A","summary":"one sentence"}';
    return fetch('https://generativelanguage.googleapis.com/v1beta/models/' + model + ':generateContent?key=' + apiKey, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }], generationConfig: { temperature: 0.1, maxOutputTokens: 300 } })
    });
  }).then(function(response) {
    if (!response.ok) return response.json().then(function(e) { throw new Error(e.error ? e.error.message : 'HTTP ' + response.status); });
    return response.json();
  }).then(function(data) {
    var raw = (data.candidates && data.candidates[0] && data.candidates[0].content && data.candidates[0].content.parts && data.candidates[0].content.parts[0]) ? data.candidates[0].content.parts[0].text : '';
    if (!raw) return { category: 'Forms & Templates', title: filename, author: 'N/A', date: 'N/A', summary: '' };
    var clean = raw.replace(new RegExp('```json', 'g'), '').replace(new RegExp('```', 'g'), '').trim();
    try { return JSON.parse(clean); } catch(e) {
      var s = clean.indexOf('{'), en = clean.lastIndexOf('}');
      if (s >= 0 && en > s) { try { return JSON.parse(clean.slice(s, en+1)); } catch(e2) {} }
      var fn = filename.replace(/\.[^.]+$/, '').replace(/[_-]/g, ' ');
      return { category: guessFromFilename(filename) || 'Forms & Templates', title: fn, author: 'N/A', date: 'N/A', summary: '' };
    }
  });
}

function normalizeCategory(raw) {
  if (!raw) return 'Forms & Templates';
  var exact = CATEGORIES.find(function(c) { return c === raw; });
  if (exact) return exact;
  var lower = raw.toLowerCase();
  var kws = {
    'R&D Proposals':['r&d proposal','research proposal','rd proposal','project proposal'],
    'Activity Proposals':['activity proposal','seminar','training','workshop'],
    'Progress Reports':['progress report','status report','quarterly'],
    'Terminal Reports':['terminal report','final report','completion'],
    'TEG Reports':['teg','technical evaluation'],
    'Publications & Presentations':['publication','presentation','journal','article','conference','manuscript','paper','lucagbo'],
    'PPMP & Procurement':['ppmp','purchase','procurement','rfq','canvass'],
    'MOA / MOU Documents':['moa','mou','memorandum','agreement'],
    'Certificates & Awards':['certificate','award','recognition'],
    'Monitoring & Evaluation':['monitoring','evaluation','m&e'],
    'Completed Researches':['completed research','finished research'],
    'Letter Requests':['letter request','request letter','endorsement'],
    'Forms & Templates':['form','template','blank'],
    'Creative Works':['creative','artwork','literary'],
    'Extension Documents':['extension','community','outreach']
  };
  for (var cat in kws) {
    for (var i = 0; i < kws[cat].length; i++) {
      if (lower.indexOf(kws[cat][i]) >= 0) return cat;
    }
  }
  return 'Forms & Templates';
}

function populatePreview(d) {
  var cat = normalizeCategory(d.category);
  d.category = cat;
